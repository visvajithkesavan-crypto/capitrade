# Supabase — frontend (public, safe to expose in browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Backend API base URL (e.g. https://your-backend.railway.app)
NEXT_PUBLIC_API_URL=

# OpenRouter (backend only — never expose in browser)
OPENROUTER_API_KEY=

# Finnhub market data API key (backend only)
FINNHUB_API_KEY=
